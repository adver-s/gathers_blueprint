DATABASE_URL=postgresql+asyncpg://<username>:<password>@<host>:5432/<database_name>

# 本番相当で動かすとき: alembic upgrade head 済みの DB と、フロント実オリジンを CORS_ORIGINS（または CORS_ORIGIN_REGEX）に含める。

# フロントのオリジン（カンマ区切り）。localhost と 127.0.0.1 は別扱いのため、どちらか一方だけでももう一方が自動補完されます。
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3004,http://localhost:3004
#
# Next の Network URL（192.168.x.x / 10.x / 172.16–31 / Tailscale 100.64–100.127 など）を使うときの CORS。
# 既定で LAN 向け正規表現が有効（本番では CORS_ALLOW_LAN_DEV=false 推奨）。
# CORS_ALLOW_LAN_DEV=true
# 上記の代わりに独自正規表現だけ使う場合:
# CORS_ORIGIN_REGEX=^https?://192\.168\.\d{1,3}\.\d{1,3}(:\d{1,5})?$

# プレースホルダ (xxxx / 全部 x) のままだと Cognito が「client does not exist」で失敗します。コンソールの実 ID を貼ること。
# COGNITO_USER_POOL_ID=ap-northeast-1_AbCdEfGh
# COGNITO_CLIENT_ID=26文字前後の英数字（アプリクライアント ID）
# COGNITO_REGION=ap-northeast-1
