# Copy to `.env.local` and adjust (`.env.local` is gitignored).

# FastAPI のオリジン（例）。未設定時は開発中 localhost API にフォールバックする処理あり。
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# 画像 URL の基底（オプション）
# NEXT_PUBLIC_IMAGE_BASE_URL=

# `true` または `1` でイベント API をモックに切替（UI 確認用。本番では未設定推奨）
# NEXT_PUBLIC_MOCK_EVENTS=true
