# Copy to `.env.local` and adjust (`.env.local` is gitignored).

# `next dev` のとき、`app/api-proxy` の Route Handler が FastAPI へ転送する宛先（省略時は http://127.0.0.1:8000）
# INTERNAL_API_ORIGIN=http://127.0.0.1:8000

# FastAPI のオリジン（例）。開発では未設定でも localhost 向けにフォールバックするが、
# 本番・ステージング（Vercel 等で localhost 以外のホスト）では必ず実 API の URL を設定すること。
# 未設定だと同一オリジンへ誤 fetch し、プロフィール等が失敗することがある。
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# 画像 URL の基底（オプション）
# NEXT_PUBLIC_IMAGE_BASE_URL=

# `true` または `1` でイベント API をモックに切替（UI 確認用。本番では未設定推奨）
# FE–BE–DB 連携確認では未設定のままにする（true だと POST/GET /events が API に届かない）
# NEXT_PUBLIC_MOCK_EVENTS=true

# .env.local         最優先。gitignore推奨。秘密情報はここ
# .env.development   next dev 時だけ読まれる
# .env.production    next build/start 時だけ読まれる
# .env               全環境で読まれる。デフォルト値を書く

# ご意見・トラブル報告用 Google フォームの URL（設定画面の「入力フォーム」から開く）
NEXT_PUBLIC_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSfWb_7ygGhRSAsS77ckjVgJ6-Xe2vEgZlJG_XFgErizejSRKA/viewform?usp=header
